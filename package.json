{
  "name": "claudian-mobile",
  "version": "1.0.0",
  "description": "Claude Code embedded in Obsidian Mobile - optimized for Android and iOS",
  "main": "main.js",
  "engines": {
    "node": ">=18 <25"
  },
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --external:obsidian --outfile=main.js --watch",
    "build": "esbuild src/main.ts --bundle --external:obsidian --outfile=main.js --minify",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix"
  },
  "keywords": [
    "claude-code",
    "claude",
    "obsidian",
    "obsidian-plugin",
    "android",
    "ios",
    "mobile",
    "ai"
  ],
  "author": "Spartanis",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.50.0",
    "obsidian": "latest",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tslib": "^2.6.0"
  }
}
